      "source": [
        "# 🎧 Feature Extraction: Log-Mel Only + Oversampling (Fix Hungry)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ✅ Import
",
        "import os
",
        "import numpy as np
",
        "import librosa
",
        "import matplotlib.pyplot as plt
",
        "import librosa.display
",
        "from sklearn.preprocessing import LabelEncoder, StandardScaler
",
        "from imblearn.over_sampling import RandomOverSampler
",
        "from tqdm import tqdm
",
        "
",
        "# ✅ Settings
",
        "SAMPLE_RATE = 22050
",
        "X = np.load("X_clean3.npy", mmap_mode='r')
",
        "y = np.load("y_clean3.npy")
",
        "
",
        "# ✅ Log-Mel Extraction
",
        "def extract_logmel(signal):
",
        "    mel = librosa.feature.melspectrogram(y=signal, sr=SAMPLE_RATE, n_mels=84)
",
        "    mel_db = librosa.power_to_db(mel, ref=np.max)
",
        "    return StandardScaler().fit_transform(mel_db)
",
        "
",
        "# ✅ Extract features
",
        "print("🔍 Extracting log-Mel features...")
",
        "X_feat = [extract_logmel(x) for x in tqdm(X)]
",
        "
",
        "# ✅ Padding to max length
",
        "max_len = max(f.shape[1] for f in X_feat)
",
        "X_pad = [np.pad(f, ((0, 0), (0, max_len - f.shape[1])), mode='constant') for f in X_feat]
",
        "X_arr = np.array(X_pad)
",
        "
",
        "# ✅ Flatten & Oversample
",
        "X_flat = X_arr.reshape((X_arr.shape[0], -1))
",
        "ros = RandomOverSampler()
",
        "X_bal, y_bal = ros.fit_resample(X_flat, y)
",
        "
",
        "# ✅ Reshape Back
",
        "X_final = X_bal.reshape((-1, X_arr.shape[1], X_arr.shape[2]))
",
        "
",
        "# ✅ Save
",
        "np.save("X_logmel_balanced.npy", X_final)
",
        "np.save("y_logmel_balanced.npy", y_bal)
",
        "print("✅ Saved X_logmel_balanced.npy & y_logmel_balanced.npy")
",
        "
",
        "# ✅ Visual check (optional)
",
        "import random
",
        "idx = random.choice(range(len(X_final)))
",
        "librosa.display.specshow(X_final[idx], sr=SAMPLE_RATE, x_axis='time', y_axis='mel')
",
        "plt.title("Example Log-Mel Spectrogram")
",
        "plt.colorbar(format='%+2.0f dB')
",
        "plt.tight_layout()
",
        "plt.show()"
      ]
    }
  ],
